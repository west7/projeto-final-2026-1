# LLM provider configuration.
# Copy to .env for local development and keep real keys out of git.

# Preferred generic key name used by the backend.
LLM_API_KEY=

# Alternative accepted by the backend when LLM_API_KEY is not set.
# OPENAI_API_KEY=

LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_TIMEOUT_SECONDS=20

# Disable Gemini thinking for this short evidence-rewrite task. Leave blank for
# providers that do not accept the OpenAI-compatible reasoning_effort field.
LLM_REASONING_EFFORT=none
